# Сервер boardgames. Скопируй в apps/server/.env и заполни.

# Порт сервера (по умолчанию 3001)
PORT=3001

# Откуда пускать CORS (адрес фронта)
WEB_ORIGIN=http://localhost:5173

# Postgres. Если не задан — сервер работает в гостевом режиме (без аккаунтов).
DATABASE_URL=postgres://boardgames:boardgames@localhost:5432/boardgames

# Секрет для подписи JWT. В проде задать обязательно (длинная случайная строка).
JWT_SECRET=dev-secret-change-me
