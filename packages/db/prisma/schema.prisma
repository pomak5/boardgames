// Схема БД boardgames: аккаунты, статистика партий, словари Alias.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  nickname     String
  passwordHash String
  avatarUrl    String? // data:image/* URL (загруженный аватар); null — инициалы
  createdAt    DateTime     @default(now())
  results      GameResult[]
}

model GameResult {
  id       String   @id @default(cuid())
  game     Game
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  won      Boolean
  team     String? // команда в Коднеймс; null для Uno
  score    Int? // очки в Uno; null для Коднеймс
  playedAt DateTime @default(now())

  @@index([userId])
  @@index([userId, won]) // лидерборд: groupBy по userId с where won
  @@index([userId, playedAt]) // история партий игрока: where userId order by playedAt desc
  @@index([game])
}

enum Game {
  codenames
  uno
  alias
}

model AliasWord {
  id         String @id @default(cuid())
  word       String @unique
  difficulty String // "easy" | "medium" | "hard"

  @@index([difficulty])
}
